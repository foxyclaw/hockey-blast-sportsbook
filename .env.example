# ─── Flask ───────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ─── Databases ───────────────────────────────────────────────────────────────
# Hockey Blast DB — READ ONLY. Never write to this.
HB_DATABASE_URL=postgresql://foxyclaw:foxyhockey2026@192.168.86.83:5432/hockey_blast

# Predictions DB — read/write
PRED_DATABASE_URL=postgresql://foxyclaw:foxyhockey2026@192.168.86.83:5432/hockey_blast_predictions

# ─── Auth0 ───────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id-here
AUTH0_CLIENT_SECRET=your-client-secret-here
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_CALLBACK_URL=http://localhost:5000/auth/callback

# ─── App ─────────────────────────────────────────────────────────────────────
# How many minutes before game start picks lock (buffer for status lag)
PICK_LOCK_BUFFER_MINUTES=0

# Grader job interval in minutes
GRADER_INTERVAL_MINUTES=5
